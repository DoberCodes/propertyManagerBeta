{
	"name": "maintley",
	"version": "1.11.8",
	"private": true,
	"type": "module",
	"homepage": "https://maintleyapp.com",
	"dependencies": {
		"@capacitor/android": "^8.0.2",
		"@capacitor/browser": "^8.0.0",
		"@capacitor/cli": "^8.0.2",
		"@capacitor/core": "^8.0.2",
		"@capacitor/geolocation": "^8.0.0",
		"@capacitor/push-notifications": "^8.0.0",
		"@fortawesome/fontawesome-svg-core": "^6.5.1",
		"@fortawesome/free-brands-svg-icons": "^6.5.1",
		"@fortawesome/free-regular-svg-icons": "^6.5.1",
		"@fortawesome/free-solid-svg-icons": "^6.5.1",
		"@fortawesome/react-fontawesome": "^0.2.0",
		"@octokit/rest": "^22.0.1",
		"@reduxjs/toolkit": "^1.9.7",
		"@stripe/stripe-js": "^8.7.0",
		"@testing-library/jest-dom": "^6.1.5",
		"@testing-library/react": "^14.1.2",
		"@testing-library/user-event": "^14.5.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.10.5",
		"@types/styled-components": "^5.1.34",
		"@typescript-eslint/eslint-plugin": "^6.17.0",
		"axios": "^1.6.5",
		"firebase": "^12.8.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-hash-link": "^1.0.2",
		"react-is": "^18.2.0",
		"react-redux": "^8.1.3",
		"react-router-dom": "^6.21.0",
		"react-router-hash-link": "^2.4.3",
		"react-scripts": "5.0.1",
		"recharts": "^3.7.0",
		"redux": "^4.2.1",
		"redux-thunk": "^2.4.2",
		"styled-components": "^6.1.0",
		"typescript": "^5.3.3",
		"web-vitals": "^2.1.4"
	},
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"test": "react-scripts test",
		"test:ci": "react-scripts test --watchAll=false --passWithNoTests",
		"test:build": "yarn test:ci && yarn build",
		"validate": "yarn test:ci && yarn build",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:debug": "playwright test --debug",
		"e2e:chrome": "playwright test --project=chromium",
		"e2e:firefox": "playwright test --project=firefox",
		"e2e:webkit": "playwright test --project=webkit",
		"e2e:report": "playwright show-report",
		"e2e:clean": "rm -rf test-results playwright-report .auth",
		"e2e:full": "timeout 3600 playwright test && timeout 30 npm run e2e:clean",
		"e2e:ci": "timeout 3600 playwright test && timeout 30 npm run e2e:clean && timeout 120 node scripts/cleanupFirebaseTestUsers.cjs",
		"eject": "react-scripts eject",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d build",
		"seed:firebase": "node scripts/seedFirestore.cjs",
		"init:firestore": "node scripts/initFirestore.cjs",
		"test:rules": "node scripts/testFirebaseRules.cjs",
		"test:storage": "node scripts/testStorageRules.cjs",
		"test:rules:all": "npm run test:rules && npm run test:storage",
		"cap:sync": "yarn build && npx cap sync android",
		"cap:open": "npx cap open android",
		"build:apk": "node scripts/initAppVersion.cjs && yarn build && npx cap sync android",
		"build:signed": "bash build-signed-apk.sh",
		"release:notes": "node scripts/generateReleaseNotes.cjs",
		"testDeploy": "bash build-signed-apk.sh --dry-run"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"overrides": {
		"typescript": "^5.3.3"
	},
	"devDependencies": {
		"@babel/plugin-proposal-private-property-in-object": "^7.21.11",
		"@capacitor/assets": "^3.0.5",
		"@playwright/test": "^1.58.2",
		"@types/babel__helper-module-imports": "^7",
		"@types/node-fetch": "^2.6.13",
		"@types/react-is": "^18",
		"@typescript-eslint/parser": "^6.17.0",
		"dotenv": "^17.2.3",
		"firebase-admin": "^13.6.0",
		"firebase-tools": "^15.5.1",
		"gh-pages": "^6.1.1",
		"node-fetch": "^3.3.2",
		"sharp": "^0.34.5",
		"ts-node": "^10.9.2"
	}
}
