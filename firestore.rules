rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    function callerMembershipId(accountId) {
      return accountId + '_' + request.auth.uid;
    }

    function hasMembership(accountId) {
      return exists(/databases/$(database)/documents/accountMemberships/$(callerMembershipId(accountId)));
    }

    function membershipData(accountId) {
      return get(/databases/$(database)/documents/accountMemberships/$(callerMembershipId(accountId))).data;
    }

    function isActiveMember(accountId) {
      return isAuthenticated() &&
        hasMembership(accountId) &&
        (
          !('status' in membershipData(accountId)) ||
          membershipData(accountId).status == 'active'
        );
    }

    function hasAnyRole(accountId, roles) {
      return isActiveMember(accountId) &&
        membershipData(accountId).roles.hasAny(roles);
    }

    function canReadAccount(accountId) {
      return isActiveMember(accountId);
    }

    function canManageAccount(accountId) {
      return hasAnyRole(accountId, ['account_owner', 'admin', 'manager']);
    }

    function callerUserDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function callerUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAccountOwnerOrAdmin(accountId) {
      return canManageAccount(accountId);
    }

    function canManageFamilyMemberRole(userId) {
      return isAuthenticated() &&
        userId != request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        canManageAccount(get(/databases/$(database)/documents/users/$(userId)).data.accountId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['role', 'updatedAt']);
    }

    // Family membership helper for read-only access paths.
    function isFamilyMember(accountId) {
      return isAuthenticated() &&
        (
          request.auth.uid == accountId ||
          get(/databases/$(database)/documents/familyAccounts/$(accountId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/familyAccounts/$(accountId)).data.memberIds
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) || canManageFamilyMemberRole(userId);
      allow delete: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    match /propertyGroups/{groupId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /properties/{propertyId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /propertyShares/{shareId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.sharedWithUserId == request.auth.uid ||
        resource.data.sharedWithEmail == getUserEmail()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.ownerId == request.auth.uid ||
        isAccountOwnerOrAdmin(request.resource.data.ownerId)
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        isAccountOwnerOrAdmin(resource.data.ownerId)
      );
    }

    match /userInvitations/{invitationId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toEmail == getUserEmail()
      );
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.fromUserId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.fromUserId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /maintenanceHistory/{historyId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /teamGroups/{groupId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /teamMembers/{memberId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /devices/{deviceId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /suites/{suiteId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /units/{unitId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      allow read: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canReadAccount(resource.data.accountId);
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    // Family account records: client read-only for members/owners.
    // All writes handled by Cloud Functions callables.
    match /familyAccounts/{accountId} {
      allow read: if canReadAccount(accountId);
      allow create, update, delete: if false;
    }

    match /accountMemberships/{membershipId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        hasAnyRole(resource.data.accountId, ['account_owner', 'admin'])
      );
      allow create, update, delete: if false;
    }

    // Family invites are function-managed only (list/revoke/resend/accept via callable).
    match /familyInvites/{inviteId} {
      allow read, write: if false;
    }

    match /tenantInvitationCodes/{codeId} {
      allow read: if isAuthenticated() && (
        ('accountId' in resource.data && canReadAccount(resource.data.accountId)) ||
        resource.data.email == getUserEmail()
      );
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /tenantProfiles/{profileId} {
      allow read: if isAuthenticated() && (
        ('accountId' in resource.data && canReadAccount(resource.data.accountId)) ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        ('accountId' in request.resource.data) &&
        canManageAccount(request.resource.data.accountId);
      allow update, delete: if isAuthenticated() &&
        ('accountId' in resource.data) &&
        canManageAccount(resource.data.accountId);
    }

    match /teamMemberInvitationCodes/{codeId} {
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.email == getUserEmail()
      );
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /appConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
