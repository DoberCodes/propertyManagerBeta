import { configureStore } from '@reduxjs/toolkit';
import { apiSlice } from './apiSlice';
import { propertySlice } from './propertySlice';
import { taskSlice } from './taskSlice';
import { contractorSlice } from './contractorSlice';
import { maintenanceSlice } from './maintenanceSlice';
import { Property, PropertyGroup } from '../Slices/propertyDataSlice';

// Mock Firebase modules
jest.mock('../../config/firebase', () => ({
	auth: {
		currentUser: { uid: 'test-user-id', email: 'test@example.com' },
	},
	db: {},
}));

jest.mock('firebase/firestore', () => ({
	doc: jest.fn(),
	getDoc: jest.fn(),
	setDoc: jest.fn(),
	updateDoc: jest.fn(),
	collection: jest.fn(),
	query: jest.fn(),
	where: jest.fn(),
	getDocs: jest.fn(),
	addDoc: jest.fn(),
	deleteDoc: jest.fn(),
	serverTimestamp: jest.fn(() => new Date()),
}));

jest.mock('firebase/auth', () => ({
	sendPasswordResetEmail: jest.fn(),
}));

describe('Family Account API Integration', () => {
	const mockGetDocs = require('firebase/firestore').getDocs;
	const mockGetDoc = require('firebase/firestore').getDoc;
	const mockAddDoc = require('firebase/firestore').addDoc;
	const mockUpdateDoc = require('firebase/firestore').updateDoc;
	const mockWhere = require('firebase/firestore').where;

	const createTestStore = () =>
		configureStore({
			reducer: {
				[apiSlice.reducerPath]: apiSlice.reducer,
			},
			middleware: (getDefaultMiddleware) =>
				getDefaultMiddleware().concat(apiSlice.middleware),
		});

	beforeEach(() => {
		jest.clearAllMocks();
	});

	describe('getPropertyGroups with family accounts', () => {
		it('should return account owner groups for family members', async () => {
			// Mock user data for family member
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			// Mock property groups owned by account owner
			const mockGroupDocs = [
				{
					id: 'group-1',
					data: () => ({
						userId: 'account-owner-id',
						name: 'My Properties',
						createdAt: new Date(),
						updatedAt: new Date(),
					}),
				},
				{
					id: 'group-2',
					data: () => ({
						userId: 'account-owner-id',
						name: 'Shared Properties',
						createdAt: new Date(),
						updatedAt: new Date(),
					}),
				},
			];

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockGetDocs.mockResolvedValue({
				docs: mockGroupDocs,
			});

			const store = createTestStore();
			await store.dispatch(apiSlice.endpoints.getPropertyGroups.initiate());

			expect(mockWhere).toHaveBeenCalledWith(
				'userId',
				'==',
				'account-owner-id',
			);
		});

		it('should return own groups for account owners', async () => {
			// Mock user data for account owner
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'owner@example.com',
					accountId: 'test-user-id',
					isAccountOwner: true,
				}),
			};

			mockGetDoc.mockResolvedValue(mockUserDoc);

			const store = createTestStore();
			await store.dispatch(apiSlice.endpoints.getPropertyGroups.initiate());

			// Should query for test-user-id (same as current user)
			expect(mockWhere).toHaveBeenCalledWith('userId', '==', 'test-user-id');
		});
	});

	describe('getProperties with family accounts', () => {
		it('should fetch properties from account owner groups', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			const mockGroupDocs = [
				{
					id: 'group-1',
					data: () => ({
						userId: 'account-owner-id',
						name: 'My Properties',
					}),
				},
			];

			const mockPropertyDocs = [
				{
					id: 'property-1',
					data: () => ({
						groupId: 'group-1',
						title: 'Test Property',
						userId: 'account-owner-id', // Should be account owner
					}),
				},
			];

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockGetDocs
				.mockResolvedValueOnce({ docs: mockGroupDocs }) // Groups query
				.mockResolvedValueOnce({ docs: mockPropertyDocs }); // Properties query

			const store = createTestStore();
			await store.dispatch(apiSlice.endpoints.getProperties.initiate());

			expect(mockGetDocs.mock.calls.length).toBeGreaterThanOrEqual(2);
			// First call should get groups for account-owner-id
			// Second call should get properties for those groups
		});
	});

	describe('createProperty with family accounts', () => {
		it('should assign property to account owner', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockAddDoc.mockResolvedValue({ id: 'new-property-id' });

			const newProperty: Property = {
				groupId: 'group-1',
				title: 'New Family Property',
				slug: 'new-family-property',
				address: '123 Family St',
				id: '',
				userId: '',
			};

			const store = createTestStore();
			await store.dispatch(
				apiSlice.endpoints.createProperty.initiate(newProperty),
			);

			expect(mockAddDoc).toHaveBeenCalled();
			const [, payload] = mockAddDoc.mock.calls[0];
			expect(payload).toEqual(
				expect.objectContaining({
					...newProperty,
					userId: 'account-owner-id', // Should be account owner, not current user
					createdAt: expect.any(String),
					updatedAt: expect.any(String),
				}),
			);
		});

		it('should assign property to current user if they are account owner', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'owner@example.com',
					accountId: 'test-user-id',
					isAccountOwner: true,
				}),
			};

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockAddDoc.mockResolvedValue({ id: 'new-property-id' });

			const newProperty: Property = {
				groupId: 'group-1',
				title: 'New Owner Property',
				slug: 'new-owner-property',
				address: '123 Owner St',
				id: '',
				userId: '',
			};

			const store = createTestStore();
			await store.dispatch(
				apiSlice.endpoints.createProperty.initiate(newProperty),
			);

			expect(mockAddDoc).toHaveBeenCalled();
			const [, payload] = mockAddDoc.mock.calls[0];
			expect(payload).toEqual(
				expect.objectContaining({
					...newProperty,
					userId: 'test-user-id', // Should be current user since they're owner
					createdAt: expect.any(String),
					updatedAt: expect.any(String),
				}),
			);
		});
	});

	describe('createPropertyGroup with family accounts', () => {
		it('should assign property group to account owner', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockAddDoc.mockResolvedValue({ id: 'new-group-id' });

			const newGroup: PropertyGroup = {
				name: 'Family Properties',
				userId: 'account-owner-id',
				id: '',
			};

			const store = createTestStore();
			await store.dispatch(
				apiSlice.endpoints.createPropertyGroup.initiate(newGroup),
			);

			expect(mockAddDoc).toHaveBeenCalled();
			const [, payload] = mockAddDoc.mock.calls[0];
			expect(payload).toEqual(
				expect.objectContaining({
					...newGroup,
					userId: 'account-owner-id', // Should be account owner
					createdAt: expect.any(String),
					updatedAt: expect.any(String),
				}),
			);
		});
	});

	describe('getTasks with family accounts', () => {
		it('should fetch tasks from account owner properties', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			const mockGroupDocs = [
				{
					id: 'group-1',
					data: () => ({
						userId: 'account-owner-id',
						name: 'My Properties',
					}),
				},
			];

			const mockPropertyDocs = [
				{
					id: 'property-1',
					data: () => ({
						groupId: 'group-1',
						title: 'Test Property',
					}),
				},
			];

			const mockTaskDocs = [
				{
					id: 'task-1',
					data: () => ({
						propertyId: 'property-1',
						title: 'Test Task',
						status: 'pending',
					}),
				},
			];

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockGetDocs
				.mockResolvedValueOnce({ docs: mockGroupDocs }) // Groups
				.mockResolvedValueOnce({ docs: mockPropertyDocs }) // Properties
				.mockResolvedValueOnce({ docs: mockTaskDocs }); // Tasks

			const store = createTestStore();
			await store.dispatch(taskSlice.endpoints.getTasks.initiate());

			expect(mockGetDocs.mock.calls.length).toBeGreaterThanOrEqual(3);
			// Should query for account-owner-id groups, then properties, then tasks
		});
	});

	describe('getContractors with family accounts', () => {
		it('should fetch contractors from account owner properties', async () => {
			const mockUserDoc = {
				exists: () => true,
				data: () => ({
					email: 'family@example.com',
					accountId: 'account-owner-id',
					isAccountOwner: false,
				}),
			};

			const mockGroupDocs = [
				{
					id: 'group-1',
					data: () => ({
						userId: 'account-owner-id',
						name: 'My Properties',
					}),
				},
			];

			mockGetDoc.mockResolvedValue(mockUserDoc);
			mockGetDocs.mockResolvedValue({ docs: mockGroupDocs });

			const store = createTestStore();
			await store.dispatch(apiSlice.endpoints.getContractors.initiate());

			expect(mockGetDocs).toHaveBeenCalled();
		});
	});
});
