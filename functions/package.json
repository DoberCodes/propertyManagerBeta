{
	"name": "functions",
	"private": true,
	"main": "lib/index.js",
	"engines": {
		"node": "20"
	},
	"scripts": {
		"build": "tsc",
		"serve": "npm run build && firebase emulators:start --only functions",
		"deploy": "npm run build && firebase deploy --only functions",
		"test": "npx ts-node test-stripe-integration.ts",
		"test:sandbox": "npx ts-node test-stripe-sandbox.ts",
		"test:cards:sandbox": "npx ts-node test-stripe-card-scenarios-sandbox.ts",
		"test:webhook:sandbox": "npx ts-node test-stripe-webhook-sandbox.ts",
		"migrate:account-rbac": "npm run build && node lib/scripts/migrate-account-rbac.js",
		"check-resend": "node scripts/check-resend.cjs",
		"stripe:webhook": "stripe listen --forward-to localhost:3000/webhook",
		"stripe:webhook:auto": "bash listen-and-update-webhook-secret.sh"
	},
	"dependencies": {
		"dotenv": "^17.2.3",
		"firebase-admin": "^12.0.0",
		"firebase-functions": "^7.0.5",
		"resend": "^4.7.0",
		"stripe": "^14.17.0"
	},
	"devDependencies": {
		"firebase-tools": "^15.5.1",
		"typescript": "^5.3.3"
	}
}
