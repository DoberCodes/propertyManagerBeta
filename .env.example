# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase credentials

REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:3001/api

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys (use test keys for development)
REACT_APP_STRIPE_PUBLIC_KEY=your_stripe_test_public_key_here
REACT_APP_STRIPE_FREE_PLAN_ID=price_free_test_id
REACT_APP_STRIPE_HOMEOWNER_PLAN_ID=price_homeowner_test_id
REACT_APP_STRIPE_BASIC_PLAN_ID=price_basic_test_id
REACT_APP_STRIPE_PROFESSIONAL_PLAN_ID=price_professional_test_id

# Android Release Build Configuration
# Used by build-signed-apk.sh for automated APK signing
# Leave empty to prompt during build, or set for non-interactive builds
KEYSTORE_PASSWORD=your_keystore_password_here
KEYSTORE_KEY_PASSWORD=your_key_password_here

# Promo Codes (for testing)
# Set these to enable special promo codes for testing different subscription states
REACT_APP_UNLIMITED_TRIAL_PROMO_CODE=your_unlimited_trial_code
REACT_APP_EXPIRED_TRIAL_PROMO_CODE=your_expired_trial_code